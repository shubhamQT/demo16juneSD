{
  "id": "add-to-cart-and-verify-cart-count",
  "testPlanId": "4bd398e3-f881-41a0-9fc5-77729651c89d",
  "requirementId": "7a5427e7-e0c5-4465-8450-77ef6b2b1046",
  "suiteName": "Product Listing - E2E",
  "case": {
    "id": "add-to-cart-and-verify-cart-count",
    "title": "User adds a product to the cart and verifies cart count",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Navigate to the login page",
        "value": "https://www.saucedemo.com/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter username",
        "locatorHint": "[data-test='username']",
        "value": "standard_user"
      },
      {
        "id": "step-3",
        "action": "fill",
        "targetDescription": "Enter password",
        "locatorHint": "[data-test='password']",
        "value": "secret_sauce"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click the login button",
        "locatorHint": "[data-test='login-button']"
      },
      {
        "id": "step-5",
        "action": "tap",
        "targetDescription": "Click Add to Cart for Sauce Labs Backpack",
        "locatorHint": "[data-test='add-to-cart-sauce-labs-backpack']"
      },
      {
        "id": "step-6",
        "action": "assertText",
        "targetDescription": "Verify cart icon shows 1 item",
        "locatorHint": ".shopping_cart_badge",
        "assertion": "1"
      },
      {
        "id": "step-7",
        "action": "assertText",
        "targetDescription": "Verify Add to Cart button changed to Remove",
        "locatorHint": "[data-test='remove-sauce-labs-backpack']",
        "assertion": "Remove"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
