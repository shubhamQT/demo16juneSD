{
  "id": "navigate-to-product-detail-and-back",
  "testPlanId": "4bd398e3-f881-41a0-9fc5-77729651c89d",
  "requirementId": "7a5427e7-e0c5-4465-8450-77ef6b2b1046",
  "suiteName": "Product Listing - E2E",
  "case": {
    "id": "navigate-to-product-detail-and-back",
    "title": "User navigates to product detail page and back to product listing",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Navigate to the login page",
        "value": "https://www.saucedemo.com/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter username",
        "locatorHint": "[data-test='username']",
        "value": "standard_user"
      },
      {
        "id": "step-3",
        "action": "fill",
        "targetDescription": "Enter password",
        "locatorHint": "[data-test='password']",
        "value": "secret_sauce"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click the login button",
        "locatorHint": "[data-test='login-button']"
      },
      {
        "id": "step-5",
        "action": "tap",
        "targetDescription": "Click on Sauce Labs Backpack product name",
        "locatorHint": ".inventory_item_name"
      },
      {
        "id": "step-6",
        "action": "assertText",
        "targetDescription": "Verify product detail page shows Sauce Labs Backpack",
        "locatorHint": ".inventory_details_name",
        "assertion": "Sauce Labs Backpack"
      },
      {
        "id": "step-7",
        "action": "tap",
        "targetDescription": "Click Back to Products button",
        "locatorHint": "[data-test='back-to-products']"
      },
      {
        "id": "step-8",
        "action": "assertVisible",
        "targetDescription": "Verify Inventory page is displayed",
        "locatorHint": ".inventory_list"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
