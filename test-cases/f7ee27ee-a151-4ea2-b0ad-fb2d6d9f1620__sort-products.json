{
  "id": "sort-products",
  "testPlanId": "f7ee27ee-a151-4ea2-b0ad-fb2d6d9f1620",
  "requirementId": "5d5145d4-949b-4ca5-86a7-4f89916ae06c",
  "suiteName": "Product Listing E2E",
  "case": {
    "id": "sort-products",
    "title": "User sorts products and verifies sorting order",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Navigate to login page",
        "value": "https://www.saucedemo.com/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter username",
        "locatorHint": "[data-test='username']",
        "value": "standard_user"
      },
      {
        "id": "step-3",
        "action": "fill",
        "targetDescription": "Enter password",
        "locatorHint": "[data-test='password']",
        "value": "secret_sauce"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click Login button",
        "locatorHint": "[data-test='login-button']"
      },
      {
        "id": "step-5",
        "action": "selectOption",
        "targetDescription": "Select sort option 'Price (low to high)'",
        "locatorHint": "[data-test='product_sort_container']",
        "value": "lohi"
      },
      {
        "id": "step-6",
        "action": "assertText",
        "targetDescription": "Verify first product is lowest price",
        "locatorHint": ".inventory_item_price:nth-child(1)",
        "assertion": "$7.99"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
