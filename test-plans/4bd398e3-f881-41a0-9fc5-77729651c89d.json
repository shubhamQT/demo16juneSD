        "id": "login-and-view-product-list",
        "title": "User logs in and views the product listing page",
        "priority": "P0",
        "platforms": [
          "chrome"
        ],
        "preconditions": [],
        "steps": [
          {
            "id": "step-1",
            "action": "openUrl",
            "targetDescription": "Navigate to the login page",
            "value": "https://www.saucedemo.com/"
          },
          {
            "id": "step-2",
            "action": "fill",
            "targetDescription": "Enter username",
            "locatorHint": "[data-test='username']",
            "value": "standard_user"
          },
          {
            "id": "step-3",
            "action": "fill",
            "targetDescription": "Enter password",
            "locatorHint": "[data-test='password']",
            "value": "secret_sauce"
          },
          {
            "id": "step-4",
            "action": "tap",
            "targetDescription": "Click the login button",
            "locatorHint": "[data-test='login-button']"
          },
          {
            "id": "step-5",
            "action": "assertVisible",
            "targetDescription": "Verify Inventory page is displayed",
            "locatorHint": ".inventory_list"
          },
          {
            "id": "step-6",
            "action": "assertText",
            "targetDescription": "Verify Sauce Labs Backpack is listed",
            "locatorHint": ".inventory_item_name",
            "assertion": "Sauce Labs Backpack"
          }
        ],
        "tags": [
          "@e2e",
          "@regression"
        ]
      },
